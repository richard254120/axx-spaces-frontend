import { useState, useEffect, useContext } from "react";
import { useNavigate, useSearchParams } from "react-router-dom";
import { AuthContext } from "../context/AuthContext";
import API from "../api/api";

const COUNTIES = [
  "Mombasa","Kwale","Kilifi","Tana River","Lamu","Taita Taveta",
  "Garissa","Wajir","Mandera","Marsabit","Isiolo","Meru","Tharaka Nithi",
  "Embu","Kitui","Machakos","Makueni","Nyandarua","Nyeri","Kirinyaga",
  "Murang'a","Kiambu","Turkana","West Pokot","Samburu","Trans Nzoia",
  "Uasin Gishu","Elgeyo Marakwet","Nandi","Baringo","Laikipia","Nakuru",
  "Narok","Kajiado","Kericho","Bomet","Kakamega","Vihiga","Bungoma",
  "Busia","Siaya","Kisumu","Homa Bay","Migori","Kisii","Nyamira","Nairobi City"
];

const TYPES = [
  "Bedsitter","Studio Apartment","1 Bedroom","2 Bedroom","3 Bedroom",
  "4+ Bedroom","Maisonette","Bungalow","Townhouse","Apartment Block"
];

const TYPE_ICONS = {
  "Bedsitter": "🏠",
  "Studio Apartment": "🏢",
  "1 Bedroom": "🛋️",
  "2 Bedroom": "🏡",
  "3 Bedroom": "🏘️",
  "4+ Bedroom": "🏰",
  "Maisonette": "🏗️",
  "Bungalow": "🌿",
  "Townhouse": "🏙️",
  "Apartment Block": "🏬",
};

export default function Listings() {
  const navigate = useNavigate();
  const { token } = useContext(AuthContext);
  const [searchParams] = useSearchParams();

  const [listings, setListings] = useState([]);
  const [filteredListings, setFilteredListings] = useState([]);
  const [loading, setLoading] = useState(true);
  const [error, setError] = useState("");
  const [wishlist, setWishlist] = useState(new Set());

  const [filters, setFilters] = useState({
    search: searchParams.get("search") || "",
    county: searchParams.get("county") || "",
    type: searchParams.get("type") || "",
    minPrice: searchParams.get("minPrice") || "",
    maxPrice: searchParams.get("maxPrice") || "",
  });

  const [showFiltersPanel, setShowFiltersPanel] = useState(false);

  useEffect(() => {
    const fetchListings = async () => {
      setLoading(true);
      try {
        const response = await API.get("/properties");
        const data = Array.isArray(response.data) ? response.data : response.data.properties || [];
        const approved = data.filter(p => p.status === "approved");
        setListings(approved);
        setError("");
      } catch (err) {
        console.error("Failed to load listings:", err);
        setError("Failed to load listings");
        setListings([]);
      } finally {
        setLoading(false);
      }
    };
    fetchListings();
  }, []);

  useEffect(() => {
    let filtered = listings;
    if (filters.search) {
      const s = filters.search.toLowerCase();
      filtered = filtered.filter(p =>
        p.title?.toLowerCase().includes(s) ||
        p.area?.toLowerCase().includes(s) ||
        p.description?.toLowerCase().includes(s)
      );
    }
    if (filters.county) filtered = filtered.filter(p => p.county === filters.county);
    if (filters.type) filtered = filtered.filter(p => p.type === filters.type);
    if (filters.minPrice) filtered = filtered.filter(p => p.price >= parseInt(filters.minPrice));
    if (filters.maxPrice) filtered = filtered.filter(p => p.price <= parseInt(filters.maxPrice));
    setFilteredListings(filtered);
  }, [listings, filters]);

  const handleFilterChange = (e) => {
    const { name, value } = e.target;
    setFilters(prev => ({ ...prev, [name]: value }));
  };

  const toggleWishlist = (e, id) => {
    e.stopPropagation();
    setWishlist(prev => {
      const next = new Set(prev);
      next.has(id) ? next.delete(id) : next.add(id);
      return next;
    });
  };

  const groupedCounties = filteredListings.length > 0
    ? Array.from(new Set(filteredListings.map(p => p.county)))
    : [];

  const activeFilterCount = [filters.county, filters.type, filters.minPrice, filters.maxPrice]
    .filter(Boolean).length;

  return (
    <div className="ab-root">
      <style>{css}</style>

      {/* ── TOP NAV SEARCH BAR (Airbnb style) ── */}
      <header className="ab-header">
        <div className="ab-logo">
          <svg viewBox="0 0 32 32" className="ab-logo-svg" fill="#FF385C">
            <path d="M16 1C10.925 1 6.5 6.525 6.5 11.5c0 7.5 9.5 19.5 9.5 19.5s9.5-12 9.5-19.5C25.5 6.525 21.075 1 16 1zm0 14a4.5 4.5 0 110-9 4.5 4.5 0 010 9z"/>
          </svg>
          <span className="ab-logo-text">rentals<span style={{color:"#FF385C"}}>ke</span></span>
        </div>

        <div className="ab-search-pill">
          <input
            type="text"
            name="search"
            placeholder="Search destinations..."
            value={filters.search}
            onChange={handleFilterChange}
            className="ab-search-input"
          />
          <button className="ab-search-btn" aria-label="Search">
            <svg viewBox="0 0 32 32" fill="none" stroke="white" strokeWidth="4" width="14" height="14">
              <circle cx="13" cy="13" r="8"/><line x1="19" y1="19" x2="28" y2="28"/>
            </svg>
          </button>
        </div>

        <button
          className={`ab-filter-btn ${activeFilterCount > 0 ? "ab-filter-btn--active" : ""}`}
          onClick={() => setShowFiltersPanel(p => !p)}
        >
          <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="1.5" width="16" height="16">
            <line x1="2" y1="4" x2="14" y2="4"/>
            <line x1="4" y1="8" x2="12" y2="8"/>
            <line x1="6" y1="12" x2="10" y2="12"/>
          </svg>
          Filters
          {activeFilterCount > 0 && <span className="ab-filter-badge">{activeFilterCount}</span>}
        </button>
      </header>

      {/* ── CATEGORY PILLS ── */}
      <div className="ab-categories-bar">
        <div className="ab-categories-scroll">
          <button
            className={`ab-category-pill ${!filters.type ? "ab-category-pill--active" : ""}`}
            onClick={() => setFilters(p => ({ ...p, type: "" }))}
          >
            <span className="ab-cat-icon">🏠</span>
            <span>All</span>
          </button>
          {TYPES.map(t => (
            <button
              key={t}
              className={`ab-category-pill ${filters.type === t ? "ab-category-pill--active" : ""}`}
              onClick={() => setFilters(p => ({ ...p, type: p.type === t ? "" : t }))}
            >
              <span className="ab-cat-icon">{TYPE_ICONS[t]}</span>
              <span>{t}</span>
            </button>
          ))}
        </div>
      </div>

      {/* ── FILTERS PANEL (dropdown) ── */}
      {showFiltersPanel && (
        <div className="ab-filters-panel">
          <div className="ab-filters-inner">
            <h3 className="ab-filters-title">Filters</h3>
            <div className="ab-filters-grid">
              <div className="ab-filter-group">
                <label className="ab-filter-label">County</label>
                <select name="county" value={filters.county} onChange={handleFilterChange} className="ab-filter-select">
                  <option value="">All Counties</option>
                  {COUNTIES.map(c => <option key={c} value={c}>{c}</option>)}
                </select>
              </div>
              <div className="ab-filter-group">
                <label className="ab-filter-label">Property Type</label>
                <select name="type" value={filters.type} onChange={handleFilterChange} className="ab-filter-select">
                  <option value="">All Types</option>
                  {TYPES.map(t => <option key={t} value={t}>{t}</option>)}
                </select>
              </div>
              <div className="ab-filter-group">
                <label className="ab-filter-label">Min Price (KSh)</label>
                <input type="number" name="minPrice" placeholder="0" value={filters.minPrice} onChange={handleFilterChange} className="ab-filter-select" />
              </div>
              <div className="ab-filter-group">
                <label className="ab-filter-label">Max Price (KSh)</label>
                <input type="number" name="maxPrice" placeholder="Any" value={filters.maxPrice} onChange={handleFilterChange} className="ab-filter-select" />
              </div>
            </div>
            <div className="ab-filters-actions">
              <button className="ab-filters-clear" onClick={() => { setFilters({ search: "", county: "", type: "", minPrice: "", maxPrice: "" }); setShowFiltersPanel(false); }}>
                Clear all
              </button>
              <button className="ab-filters-apply" onClick={() => setShowFiltersPanel(false)}>
                Show {filteredListings.length} homes
              </button>
            </div>
          </div>
        </div>
      )}

      {/* ── RESULTS COUNT ── */}
      <div className="ab-results-bar">
        <span className="ab-results-count">
          {filteredListings.length} {filteredListings.length === 1 ? "home" : "homes"} available
        </span>
        {activeFilterCount > 0 && (
          <button className="ab-clear-link" onClick={() => setFilters({ search: "", county: "", type: "", minPrice: "", maxPrice: "" })}>
            Clear filters
          </button>
        )}
      </div>

      {/* ── ERROR ── */}
      {error && <div className="ab-error">{error}</div>}

      {/* ── MAIN CONTENT ── */}
      {loading ? (
        <div className="ab-loading">
          <div className="ab-skeleton-grid">
            {Array.from({ length: 8 }).map((_, i) => (
              <div key={i} className="ab-skeleton-card">
                <div className="ab-skeleton-img" />
                <div className="ab-skeleton-line ab-skeleton-line--wide" />
                <div className="ab-skeleton-line" />
                <div className="ab-skeleton-line ab-skeleton-line--short" />
              </div>
            ))}
          </div>
        </div>
      ) : filteredListings.length === 0 ? (
        <div className="ab-empty">
          <div className="ab-empty-icon">🔍</div>
          <h2 className="ab-empty-title">No exact matches</h2>
          <p className="ab-empty-text">Try adjusting or clearing some of your filters.</p>
          <button className="ab-empty-btn" onClick={() => setFilters({ search: "", county: "", type: "", minPrice: "", maxPrice: "" })}>
            Remove all filters
          </button>
        </div>
      ) : (
        <main className="ab-main">
          {groupedCounties.map(county => {
            const countyListings = filteredListings.filter(p => p.county === county);
            const SHOW = 5;

            return (
              <section key={county} className="ab-county-section">
                <div className="ab-county-header">
                  <h2 className="ab-county-title">Stays in {county}</h2>
                  <p className="ab-county-sub">{countyListings.length} {countyListings.length === 1 ? "place" : "places"}</p>
                </div>

                <div className="ab-cards-grid">
                  {countyListings.slice(0, SHOW).map((property, idx) => (
                    <div
                      key={property._id}
                      className="ab-card"
                      onClick={() => navigate(`/listings/${property._id}`)}
                      style={{ animationDelay: `${idx * 60}ms` }}
                    >
                      {/* Image */}
                      <div className="ab-card-img-wrap">
                        <img
                          src={property.images?.[0] || "/placeholder.jpg"}
                          alt={property.title}
                          className="ab-card-img"
                          onError={e => { e.target.src = "/placeholder.jpg"; }}
                        />
                        {/* Wishlist heart */}
                        <button
                          className={`ab-heart ${wishlist.has(property._id) ? "ab-heart--active" : ""}`}
                          onClick={e => toggleWishlist(e, property._id)}
                          aria-label="Save to wishlist"
                        >
                          <svg viewBox="0 0 32 32" width="16" height="16">
                            <path
                              d="M16 28S3 20 3 11a7 7 0 0114 0 7 7 0 0114 0c0 9-13 17-13 17z"
                              fill={wishlist.has(property._id) ? "#FF385C" : "rgba(0,0,0,0.5)"}
                              stroke={wishlist.has(property._id) ? "#FF385C" : "white"}
                              strokeWidth="2"
                            />
                          </svg>
                        </button>

                        {/* Guest Favourite badge */}
                        {property.isFeatured && (
                          <div className="ab-guest-fav">
                            Guest favourite
                          </div>
                        )}

                        {/* Dot indicators */}
                        {property.images?.length > 1 && (
                          <div className="ab-dots">
                            {property.images.slice(0, 5).map((_, i) => (
                              <span key={i} className={`ab-dot ${i === 0 ? "ab-dot--active" : ""}`} />
                            ))}
                          </div>
                        )}
                      </div>

                      {/* Card body */}
                      <div className="ab-card-body">
                        <div className="ab-card-top">
                          <h3 className="ab-card-title">{property.area}, {property.county}</h3>
                          {property.rating && (
                            <span className="ab-card-rating">
                              <svg viewBox="0 0 16 16" fill="currentColor" width="12" height="12"><path d="M8 1l1.9 3.9 4.3.6-3.1 3 .7 4.3L8 10.5l-3.8 2 .7-4.3L1.8 5.5l4.3-.6z"/></svg>
                              {property.rating.toFixed(1)}
                            </span>
                          )}
                        </div>

                        <p className="ab-card-meta">
                          {property.type}
                          {property.bedrooms ? ` · ${property.bedrooms} bed${property.bedrooms > 1 ? "s" : ""}` : ""}
                          {property.bathrooms ? ` · ${property.bathrooms} bath${property.bathrooms > 1 ? "s" : ""}` : ""}
                        </p>

                        <p className="ab-card-price">
                          <strong>KSh {Number(property.price).toLocaleString()}</strong>
                          <span className="ab-card-period"> / month</span>
                        </p>
                      </div>
                    </div>
                  ))}
                </div>

                {countyListings.length > SHOW && (
                  <div className="ab-see-all-wrap">
                    <button
                      className="ab-see-all-btn"
                      onClick={() => setFilters(p => ({ ...p, county }))}
                    >
                      Show all {countyListings.length} homes in {county}
                      <svg viewBox="0 0 16 16" fill="none" stroke="currentColor" strokeWidth="2" width="14" height="14" style={{marginLeft:6}}>
                        <line x1="2" y1="8" x2="14" y2="8"/>
                        <polyline points="8,2 14,8 8,14"/>
                      </svg>
                    </button>
                  </div>
                )}

                <div className="ab-divider" />
              </section>
            );
          })}
        </main>
      )}
    </div>
  );
}

const css = `
  @import url('https://fonts.googleapis.com/css2?family=Nunito:wght@400;500;600;700;800&display=swap');

  *, *::before, *::after { box-sizing: border-box; }

  .ab-root {
    font-family: 'Nunito', -apple-system, BlinkMacSystemFont, sans-serif;
    background: #fff;
    color: #222;
    min-height: 100vh;
  }

  /* ── HEADER ── */
  .ab-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: #fff;
    border-bottom: 1px solid #ebebeb;
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 14px 24px;
  }

  .ab-logo { display: flex; align-items: center; gap: 6px; flex-shrink: 0; text-decoration: none; }
  .ab-logo-svg { width: 30px; height: 30px; }
  .ab-logo-text { font-size: 20px; font-weight: 800; color: #222; letter-spacing: -0.5px; }

  .ab-search-pill {
    flex: 1;
    max-width: 480px;
    display: flex;
    align-items: center;
    border: 1px solid #dddddd;
    border-radius: 40px;
    padding: 0 4px 0 16px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.08);
    transition: box-shadow 0.2s;
    margin: 0 auto;
  }
  .ab-search-pill:focus-within {
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
    border-color: #b0b0b0;
  }

  .ab-search-input {
    flex: 1;
    border: none;
    outline: none;
    font-family: inherit;
    font-size: 14px;
    font-weight: 500;
    color: #222;
    background: transparent;
    padding: 10px 0;
  }
  .ab-search-input::placeholder { color: #717171; }

  .ab-search-btn {
    width: 34px; height: 34px;
    border-radius: 50%;
    background: #FF385C;
    border: none;
    display: flex; align-items: center; justify-content: center;
    cursor: pointer;
    flex-shrink: 0;
    transition: background 0.2s, transform 0.15s;
  }
  .ab-search-btn:hover { background: #e0001b; transform: scale(1.05); }

  .ab-filter-btn {
    display: flex; align-items: center; gap: 6px;
    padding: 10px 16px;
    border: 1px solid #dddddd;
    border-radius: 12px;
    background: #fff;
    font-family: inherit;
    font-size: 13px;
    font-weight: 600;
    color: #222;
    cursor: pointer;
    position: relative;
    transition: box-shadow 0.2s;
    white-space: nowrap;
  }
  .ab-filter-btn:hover { box-shadow: 0 2px 8px rgba(0,0,0,0.12); }
  .ab-filter-btn--active { border-color: #222; }

  .ab-filter-badge {
    position: absolute;
    top: -6px; right: -6px;
    background: #222;
    color: #fff;
    border-radius: 50%;
    width: 18px; height: 18px;
    font-size: 11px;
    display: flex; align-items: center; justify-content: center;
    font-weight: 700;
  }

  /* ── CATEGORIES BAR ── */
  .ab-categories-bar {
    border-bottom: 1px solid #ebebeb;
    padding: 0 24px;
    background: #fff;
    position: sticky;
    top: 65px;
    z-index: 90;
  }
  .ab-categories-scroll {
    display: flex;
    gap: 0;
    overflow-x: auto;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .ab-categories-scroll::-webkit-scrollbar { display: none; }

  .ab-category-pill {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    padding: 12px 16px;
    border: none;
    border-bottom: 2px solid transparent;
    background: transparent;
    font-family: inherit;
    font-size: 11px;
    font-weight: 600;
    color: #717171;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s, border-color 0.15s;
    flex-shrink: 0;
  }
  .ab-category-pill:hover { color: #222; }
  .ab-category-pill--active { color: #222; border-bottom-color: #222; }

  .ab-cat-icon { font-size: 22px; line-height: 1; }

  /* ── FILTERS PANEL ── */
  .ab-filters-panel {
    position: fixed;
    inset: 0;
    z-index: 200;
    background: rgba(0,0,0,0.5);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    animation: ab-fade-in 0.2s ease;
  }
  @keyframes ab-fade-in { from { opacity: 0; } to { opacity: 1; } }

  .ab-filters-inner {
    background: #fff;
    border-radius: 20px 20px 0 0;
    padding: 32px 28px 40px;
    width: 100%;
    max-width: 600px;
    animation: ab-slide-up 0.3s cubic-bezier(0.32, 0.72, 0, 1);
  }
  @keyframes ab-slide-up { from { transform: translateY(60px); opacity: 0; } to { transform: translateY(0); opacity: 1; } }

  .ab-filters-title { font-size: 18px; font-weight: 800; margin: 0 0 24px; color: #222; }

  .ab-filters-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 28px;
  }

  .ab-filter-group { display: flex; flex-direction: column; gap: 6px; }
  .ab-filter-label { font-size: 12px; font-weight: 700; color: #717171; text-transform: uppercase; letter-spacing: 0.5px; }

  .ab-filter-select {
    padding: 12px 14px;
    border: 1px solid #dddddd;
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    color: #222;
    background: #fff;
    outline: none;
    transition: border-color 0.15s, box-shadow 0.15s;
    -webkit-appearance: none;
  }
  .ab-filter-select:focus { border-color: #222; box-shadow: 0 0 0 2px rgba(34,34,34,0.1); }

  .ab-filters-actions { display: flex; justify-content: space-between; align-items: center; }

  .ab-filters-clear {
    background: none; border: none; font-family: inherit;
    font-size: 14px; font-weight: 700; color: #222;
    cursor: pointer; padding: 10px 0;
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .ab-filters-apply {
    padding: 14px 28px;
    background: #222;
    color: #fff;
    border: none;
    border-radius: 10px;
    font-family: inherit;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
  }
  .ab-filters-apply:hover { background: #000; transform: translateY(-1px); }

  /* ── RESULTS BAR ── */
  .ab-results-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 16px 24px 0;
    max-width: 1360px;
    margin: 0 auto;
  }
  .ab-results-count { font-size: 13px; font-weight: 600; color: #222; }
  .ab-clear-link {
    font-size: 13px; font-weight: 700; color: #222;
    background: none; border: none; cursor: pointer;
    text-decoration: underline; text-underline-offset: 3px;
    font-family: inherit;
  }

  /* ── ERROR ── */
  .ab-error {
    margin: 16px 24px;
    padding: 14px 16px;
    background: #fff0f0;
    border: 1px solid #ffcdd2;
    border-radius: 10px;
    color: #c62828;
    font-size: 13px;
    font-weight: 600;
  }

  /* ── LOADING SKELETONS ── */
  .ab-loading { padding: 24px; max-width: 1360px; margin: 0 auto; }
  .ab-skeleton-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }
  .ab-skeleton-card { display: flex; flex-direction: column; gap: 10px; }
  .ab-skeleton-img {
    height: 240px; border-radius: 16px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: ab-shimmer 1.4s infinite;
  }
  .ab-skeleton-line {
    height: 14px; border-radius: 6px;
    background: linear-gradient(90deg, #f0f0f0 25%, #e8e8e8 50%, #f0f0f0 75%);
    background-size: 200% 100%;
    animation: ab-shimmer 1.4s infinite;
    width: 70%;
  }
  .ab-skeleton-line--wide { width: 90%; }
  .ab-skeleton-line--short { width: 40%; }
  @keyframes ab-shimmer { 0% { background-position: 200% 0; } 100% { background-position: -200% 0; } }

  /* ── EMPTY ── */
  .ab-empty {
    text-align: center;
    padding: 80px 20px;
  }
  .ab-empty-icon { font-size: 48px; margin-bottom: 16px; }
  .ab-empty-title { font-size: 24px; font-weight: 800; color: #222; margin: 0 0 8px; }
  .ab-empty-text { font-size: 14px; color: #717171; margin: 0 0 24px; }
  .ab-empty-btn {
    padding: 14px 24px;
    background: #fff;
    border: 1.5px solid #222;
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 700;
    color: #222;
    cursor: pointer;
    transition: background 0.15s;
  }
  .ab-empty-btn:hover { background: #f7f7f7; }

  /* ── MAIN / SECTIONS ── */
  .ab-main { max-width: 1360px; margin: 0 auto; padding: 24px 24px 40px; }

  .ab-county-section { margin-bottom: 48px; }

  .ab-county-header { margin-bottom: 20px; }
  .ab-county-title { font-size: 22px; font-weight: 800; color: #222; margin: 0 0 4px; }
  .ab-county-sub { font-size: 13px; color: #717171; margin: 0; }

  /* ── CARDS GRID ── */
  .ab-cards-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 24px;
  }

  /* ── CARD ── */
  .ab-card {
    cursor: pointer;
    animation: ab-card-in 0.4s ease both;
  }
  @keyframes ab-card-in { from { opacity: 0; transform: translateY(12px); } to { opacity: 1; transform: translateY(0); } }

  .ab-card-img-wrap {
    position: relative;
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 20 / 19;
    background: #f7f7f7;
    margin-bottom: 12px;
  }

  .ab-card-img {
    width: 100%; height: 100%;
    object-fit: cover;
    transition: transform 0.4s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    display: block;
  }
  .ab-card:hover .ab-card-img { transform: scale(1.04); }

  /* Heart */
  .ab-heart {
    position: absolute; top: 12px; right: 12px;
    background: none; border: none; cursor: pointer;
    padding: 6px;
    z-index: 2;
    transition: transform 0.2s;
  }
  .ab-heart:hover { transform: scale(1.15); }
  .ab-heart--active svg path { fill: #FF385C; stroke: #FF385C; }

  /* Guest Favourite */
  .ab-guest-fav {
    position: absolute; bottom: 12px; left: 12px;
    background: #fff;
    border-radius: 20px;
    padding: 4px 10px;
    font-size: 11px;
    font-weight: 700;
    color: #222;
    box-shadow: 0 2px 8px rgba(0,0,0,0.15);
  }

  /* Dots */
  .ab-dots {
    position: absolute; bottom: 10px;
    left: 50%; transform: translateX(-50%);
    display: flex; gap: 4px;
  }
  .ab-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: rgba(255,255,255,0.6);
    transition: background 0.2s;
  }
  .ab-dot--active { background: #fff; }

  /* Card body */
  .ab-card-body { padding: 0 2px; }

  .ab-card-top {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 2px;
  }

  .ab-card-title {
    font-size: 14px; font-weight: 700;
    color: #222; margin: 0;
    flex: 1;
    white-space: nowrap; overflow: hidden; text-overflow: ellipsis;
  }

  .ab-card-rating {
    display: flex; align-items: center; gap: 3px;
    font-size: 13px; font-weight: 600; color: #222;
    flex-shrink: 0; margin-left: 8px;
  }

  .ab-card-meta {
    font-size: 13px; color: #717171;
    margin: 2px 0 4px;
  }

  .ab-card-price {
    font-size: 14px; color: #222; margin: 0;
    font-weight: 500;
  }
  .ab-card-period { font-weight: 400; }

  /* ── SEE ALL ── */
  .ab-see-all-wrap { margin: 20px 0 16px; }
  .ab-see-all-btn {
    display: inline-flex; align-items: center;
    padding: 12px 20px;
    background: #fff;
    border: 1.5px solid #222;
    border-radius: 10px;
    font-family: inherit;
    font-size: 14px;
    font-weight: 700;
    color: #222;
    cursor: pointer;
    transition: background 0.15s, transform 0.15s;
  }
  .ab-see-all-btn:hover { background: #f7f7f7; transform: translateY(-1px); }

  /* ── DIVIDER ── */
  .ab-divider { height: 1px; background: #ebebeb; margin: 48px 0 0; }

  /* ── RESPONSIVE ── */
  @media (max-width: 768px) {
    .ab-header { padding: 12px 16px; gap: 10px; }
    .ab-logo-text { display: none; }
    .ab-search-pill { max-width: none; }
    .ab-main { padding: 16px 16px 40px; }
    .ab-results-bar { padding: 12px 16px 0; }
    .ab-categories-bar { padding: 0 16px; }
    .ab-cards-grid { grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 16px; }
    .ab-filters-grid { grid-template-columns: 1fr; }
  }

  @media (max-width: 480px) {
    .ab-cards-grid { grid-template-columns: 1fr 1fr; gap: 12px; }
    .ab-card-img-wrap { border-radius: 12px; }
    .ab-county-title { font-size: 18px; }
  }
`;